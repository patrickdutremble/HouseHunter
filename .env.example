NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — bypasses RLS. Used by admin/cron routes.
# NEVER expose this to the client (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server-side only (no NEXT_PUBLIC_ prefix). Used by /api/commute to call
# the Google Maps Directions API. Restrict the key to Directions API only.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Sentry error tracking. The DSN is safe to expose publicly — it's write-only
# and rate-limited. Same value used on client and server.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project
